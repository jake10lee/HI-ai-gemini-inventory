{
  "entities": {
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "A single item in the inventory extracted from an invoice.",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["purchase", "sales"],
          "description": "Whether the item was purchased or sold."
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "The date of the invoice."
        },
        "company": {
          "type": "string",
          "description": "The counterparty company name."
        },
        "brand": {
          "type": "string",
          "description": "The brand of the product."
        },
        "name": {
          "type": "string",
          "description": "The name of the product."
        },
        "spec": {
          "type": "string",
          "description": "The specification of the product."
        },
        "code": {
          "type": "string",
          "description": "The product code."
        },
        "quantity": {
          "type": "number",
          "description": "The quantity of the item."
        },
        "unit": {
          "type": "string",
          "description": "The unit of measurement."
        },
        "price": {
          "type": "number",
          "description": "The unit price of the item."
        },
        "timestamp": {
          "type": "string",
          "description": "Server timestamp of when the record was created."
        }
      },
      "required": ["type", "date", "company", "name", "quantity", "price"]
    },
    "Vendor": {
      "title": "Vendor",
      "description": "A partner or vendor company information.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "orgChart": { "type": "string" },
        "contacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "position": { "type": "string" },
              "phones": { "type": "array", "items": { "type": "string" } },
              "emails": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "timestamp": { "type": "string" }
      },
      "required": ["name"]
    },
    "TodoItem": {
      "title": "Todo Item",
      "description": "An operational task.",
      "type": "object",
      "properties": {
        "task": { "type": "string" },
        "priority": { "type": "string", "enum": ["high", "medium", "low"] },
        "dueDate": { "type": "string", "format": "date" },
        "completed": { "type": "boolean" },
        "timestamp": { "type": "string" }
      },
      "required": ["task", "priority", "dueDate", "completed"]
    },
    "VisionGoal": {
      "title": "Vision Goal",
      "description": "A strategic roadmap goal.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "description": "YYYY-MM format" },
        "timestamp": { "type": "string" }
      },
      "required": ["title", "description", "date"]
    }
  },
  "firestore": {
    "inventory": {
      "schema": "InventoryItem",
      "description": "Collection of inventory items."
    },
    "vendors": {
      "schema": "Vendor",
      "description": "Collection of business partners."
    },
    "todos": {
      "schema": "TodoItem",
      "description": "Collection of tasks."
    },
    "visions": {
      "schema": "VisionGoal",
      "description": "Collection of strategic goals."
    }
  }
}
