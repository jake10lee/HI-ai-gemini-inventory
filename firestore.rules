rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      // In a real app, you might want to check a list of authorized emails in a collection
      // For now, we use the specific email provided in the context as admin.
      return request.auth != null && 
             request.auth.token.email == "yahgong@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---

    function isValidInventoryItem(data) {
      return data.keys().hasAll(['type', 'date', 'company', 'name', 'quantity', 'price', 'timestamp']) &&
             data.type in ['purchase', 'sales'] &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.company is string && data.company.size() <= 200 &&
             data.name is string && data.name.size() <= 500 &&
             data.quantity is number && data.quantity >= 0 &&
             data.price is number && data.price >= 0 &&
             data.timestamp is timestamp &&
             (!('brand' in data) || (data.brand is string && data.brand.size() <= 200)) &&
             (!('spec' in data) || (data.spec is string && data.spec.size() <= 500)) &&
             (!('code' in data) || (data.code is string && data.code.size() <= 200)) &&
             (!('unit' in data) || (data.unit is string && data.unit.size() <= 50));
    }

    function isValidVendor(data) {
      return data.keys().hasAll(['name', 'timestamp']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             (!('orgChart' in data) || data.orgChart is string) &&
             (!('contacts' in data) || data.contacts is list) &&
             data.timestamp is timestamp;
    }

    function isValidTodo(data) {
      return data.keys().hasAll(['task', 'priority', 'dueDate', 'completed', 'timestamp']) &&
             data.task is string && data.task.size() > 0 &&
             data.priority in ['high', 'medium', 'low'] &&
             data.dueDate is string &&
             data.completed is bool &&
             data.timestamp is timestamp;
    }

    function isValidVision(data) {
      return data.keys().hasAll(['title', 'description', 'date', 'timestamp']) &&
             data.title is string && data.title.size() > 0 &&
             data.description is string &&
             data.date is string &&
             data.timestamp is timestamp;
    }

    // --- Collection Matches ---

    match /inventory/{itemId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidInventoryItem(incoming()) && incoming().timestamp == request.time;
      allow update: if isAuthenticated() && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['type', 'date', 'company', 'brand', 'name', 'spec', 'code', 'quantity', 'price', 'unit', 'ctxLink']) &&
         isValidInventoryItem(incoming()))
      );
      allow delete: if isAuthenticated();
    }

    match /vendors/{vendorId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidVendor(incoming()) && incoming().timestamp == request.time;
      allow update: if isAuthenticated() && isValidVendor(incoming());
      allow delete: if isAuthenticated();
    }

    match /todos/{todoId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidTodo(incoming()) && incoming().timestamp == request.time;
      allow update: if isAuthenticated() && isValidTodo(incoming());
      allow delete: if isAuthenticated();
    }

    match /visions/{visionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidVision(incoming()) && incoming().timestamp == request.time;
      allow update: if isAuthenticated() && isValidVision(incoming());
      allow delete: if isAuthenticated();
    }
  }
}
